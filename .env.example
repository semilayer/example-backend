# SemiLayer API — local dev or hosted
SEMILAYER_URL=https://api.semilayer.com

# Service key (sk_...) — bypasses per-lens access rules. Safe to use from
# a trusted backend; never ship this to a browser.
# Get one from `semilayer keys create --type sk` or the Console.
SEMILAYER_KEY=sk_dev_replace_me

# Lens to query — must already be defined in your sl.config.ts and pushed.
SEMILAYER_LENS=recipes
